{
  "name": "retrograde",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@8.15.9",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "pnpm --filter @retrograde/frontend dev",
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "db:migrate": "pnpm --filter @retrograde/scanner-core db:migrate",
    "format": "prettier --write .",
    "lint": "pnpm typecheck",
    "test": "pnpm -r test",
    "typecheck": "pnpm --filter @retrograde/evm-adapter typecheck && pnpm --filter @retrograde/evm-adapter build && pnpm --filter @retrograde/scanner-core typecheck && pnpm --filter @retrograde/frontend typecheck"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "@vitest/coverage-v8": "^2.1.9",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
